# ---- MongoDB ----
# Your MongoDB Atlas connection string
MONGO_URI=your_mongodb_connection_string

# ---- Auth (JWT) ----
# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# ---- Admin login (used once by `npm run seed:admin`) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# ---- Cloudinary (free image hosting: https://cloudinary.com) ----
# Found on your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- CORS ----
# Public frontend origin (comma-separated for multiple). localhost is always allowed.
CLIENT_ORIGIN=https://anushanga-munasinghe.vercel.app

# ---- Server ----
PORT=5000
